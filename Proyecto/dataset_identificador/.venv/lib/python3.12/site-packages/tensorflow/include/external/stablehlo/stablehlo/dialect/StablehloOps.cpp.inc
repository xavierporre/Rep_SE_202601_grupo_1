     ::mlir::Attribute attr = getResultAccuracyAttr();
     if(attr && (attr == ::mlir::stablehlo::ResultAccuracyAttr::get(odsBuilder.getContext(), APFloat(0.0), APFloat(0.0), 0, ::mlir::stablehlo::ResultAccuracyModeAttr::get(odsBuilder.getContext(), ::mlir::stablehlo::ResultAccuracyMode::DEFAULT))))
