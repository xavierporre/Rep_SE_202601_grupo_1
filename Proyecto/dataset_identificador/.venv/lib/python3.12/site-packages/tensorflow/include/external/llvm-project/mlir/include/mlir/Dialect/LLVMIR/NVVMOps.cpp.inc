  ::llvm::SmallVector<::mlir::OpAsmParser::UnresolvedOperand, 4> readWriteArgsOperands;
  ::llvm::SMLoc readWriteArgsOperandsLoc;
  (void)readWriteArgsOperandsLoc;
  ::llvm::SmallVector<::mlir::Type, 1> readWriteArgsTypes;
  ::llvm::SmallVector<::mlir::OpAsmParser::UnresolvedOperand, 4> predicateOperands;
  ::llvm::SMLoc predicateOperandsLoc;
