      if (attr && ::mlir::failed(__mlir_ods_local_attr_constraint_NVVMOps16(attr, "num", emitError)))
        return ::mlir::failure();
    }

    {
      ::mlir::Attribute attr = attrs.get(getShapeAttrName(opName));
      if (attr && ::mlir::failed(__mlir_ods_local_attr_constraint_NVVMOps26(attr, "shape", emitError)))
