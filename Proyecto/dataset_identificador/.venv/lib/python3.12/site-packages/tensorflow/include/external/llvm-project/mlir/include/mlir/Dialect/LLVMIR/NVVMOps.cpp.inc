  if (::mlir::failed(reader.readOptionalAttribute(prop.in_param_space)))
    return ::mlir::failure();

  if (::mlir::failed(reader.readOptionalAttribute(prop.tensormap)))
    return ::mlir::failure();

  if (::mlir::failed(reader.readOptionalAttribute(prop.uniform)))
    return ::mlir::failure();
  return ::mlir::success();
}

void PrefetchOp::writeProperties(::mlir::DialectBytecodeWriter &writer) {
