  ::mlir::OperationState __state__(location, getOperationName());
  build(builder, __state__, std::forward<decltype(res)>(res), std::forward<decltype(val)>(val), std::forward<decltype(kind)>(kind), std::forward<decltype(mask_and_clamp)>(mask_and_clamp), std::forward<decltype(abs)>(abs), std::forward<decltype(nan)>(nan));
  auto __res__ = ::llvm::dyn_cast<ReduxOp>(builder.create(__state__));
  assert(__res__ && "builder didn't return the right type");
  return __res__;
}

