  ::mlir::DictionaryAttr dict = ::llvm::dyn_cast<::mlir::DictionaryAttr>(attr);
  if (!dict) {
    emitError() << "expected DictionaryAttr to set properties";
    return ::mlir::failure();
  }
  // keep track of used keys in the input dictionary to be able to error out
  // if there are some unknown ones.
  ::mlir::DenseSet<::mlir::StringAttr> usedKeys;
  ::mlir::MLIRContext *ctx = dict.getContext();
  (void)ctx;
  {

    auto &propStorage = prop.ragged_dot_dimension_numbers;
    auto ragged_dot_dimension_numbersAttrName = ::mlir::StringAttr::get(ctx, "ragged_dot_dimension_numbers");
    auto attr = dict.get(ragged_dot_dimension_numbersAttrName);
    usedKeys.insert(ragged_dot_dimension_numbersAttrName);
    if (attr || /*isRequired=*/true) {
      if (!attr) {
        emitError() << "expected key entry for ragged_dot_dimension_numbers in DictionaryAttr to set "
                   "Properties.";
        return ::mlir::failure();
      }
      auto convertedAttr = ::llvm::dyn_cast<std::remove_reference_t<decltype(propStorage)>>(attr);
      if (convertedAttr) {
        propStorage = convertedAttr;
      } else {
        emitError() << "Invalid attribute `ragged_dot_dimension_numbers` in property conversion: " << attr;
        return ::mlir::failure();
      }
    }
  }
  {

    auto &propStorage = prop.precision_config;
    auto precision_configAttrName = ::mlir::StringAttr::get(ctx, "precision_config");
    auto attr = dict.get(precision_configAttrName);
    usedKeys.insert(precision_configAttrName);
    if (attr || /*isRequired=*/false) {
      if (!attr) {
        emitError() << "expected key entry for precision_config in DictionaryAttr to set "
                   "Properties.";
        return ::mlir::failure();
